      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(pushward_alerts_received_total[$__rate_interval]))",
          "legendFormat": "alerts received",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(pushward_activities_created_total[$__rate_interval]))",
          "legendFormat": "activities created",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(pushward_pushes_sent_total[$__rate_interval]))",
          "legendFormat": "pushes sent",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(pushward_errors_total[$__rate_interval]))",
          "legendFormat": "errors",
          "range": true,
          "refId": "D"
        }
